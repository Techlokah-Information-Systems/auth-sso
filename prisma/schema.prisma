generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(cuid())
  clerk_id String @unique
  email String @unique
  first_name String?
  last_name String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  clients Client[]

  @@index([clerk_id])
}

model Client {
  id String @id @default(cuid())
  clerk_client_id String @unique

  user_id String
  user User @relation(fields: [user_id], references: [id])
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clerk_client_id])
}